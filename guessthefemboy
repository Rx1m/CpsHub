-- messy ass function lmao (idk if it works :3)
function findClosest()
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local closest, closestDist = nil, math.huge
    
    for _,v in pairs(game.Players:GetPlayers()) do
        if v ~= plr then
            local vChar = v.Character
            if vChar and vChar:FindFirstChild("HumanoidRootPart") then
                local dist = (hrp.Position - vChar.HumanoidRootPart.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = v
                end
            end
        end
    end
    return closest
end

-- auto guess thread (gay, idk how to make it so deal with this)
function startAuto()
    if autoLoop then autoLoop:Disconnect() end
    autoLoop = rs.RenderStepped:Connect(function()
        if autoOn then
            local target = findClosest()
            if target then
                pcall(function()
                    guessRemote:FireServer(target.Name)
                    statusTxt.Text = "guessed " .. target.Name
                    statusTxt.TextColor3 = Color3.new(0.5,1,0.5)
                end)
            else
                statusTxt.Text = "nobody near"
                statusTxt.TextColor3 = Color3.new(1,0.5,0.5)
            end
            wait(0.8) -- delay so it doesnt spam too fast and rape device
        end
    end)
end

